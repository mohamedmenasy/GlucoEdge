# External upstream dependency - cloned per setup instructions, not vendored.
# No trailing slash: worktrees hold this as a symlink back to the main
# checkout's clone, and a directory-only pattern won't match a symlink.
GlucoBench

# Python
__pycache__/
*.py[cod]
*.egg-info/
venv/
.venv/
.pytest_cache/

# Data / model artifacts (regenerable, can be large)
*.csv
*.pt
*.pth
*.tflite
*.onnx
results/

# OS
.DS_Store

# Local worktrees for isolated feature work
.worktrees/
